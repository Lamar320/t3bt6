_story_print_character_text" id="QT{[]H3+5E|?Q~[Zq(;H"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="]h%|wc}Su+7a8ufSTxk)"><field name="TEXT">I've mapped the timelines - we can grab them before things go sideways</field></shadow></value><value name="label"><shadow type="text" id="A`D^oUd~ut:/z$,1yZq0"><field name="TEXT">iron man</field></shadow></value><next><block type="arcade_story_print_character_text" id="4IvToYj-|fGb3t%@{|=!"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="QRa3v#K0a;bfyCW_6i}2"><field name="TEXT">Time travel and stealing cosmic rocks ? I like this</field></shadow></value><value name="label"><shadow type="text" id="`Ift.@6UIi0R~6]BeLUf"><field name="TEXT">Thor</field></shadow></value><next><block type="arcade_story_print_character_text" id=");juks9q1k?c::P$2J#`"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="^Aqm~*p+pO0f15.npn2u"><field name="TEXT">Just don't mess up the timeline beyond repair </field></shadow></value><value name="label"><shadow type="text" id="zMh(4K4@-DU38ugyvXH%"><field name="TEXT">Cap</field></shadow></value><next><block type="arcade_story_print_character_text" id=":cS^WLJ=6v%sK;@yajP%"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="e]*IJXYWB|mR)l|oR@f:"><field name="TEXT">Focus. Tony and I take the mind and time stones . Thor you,re on the power stone , and you take the space and mind stones .</field></shadow></value><value name="label"><shadow type="text" id="`V#*ykl/|}eKJ-YSMb%N"><field name="TEXT">Cap</field></shadow></value><next><block type="arcade_story_print_character_text" id="?TfMr^wl!}yQO5uG)Sq?"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="BDc8BJtH6JZs(/ne@t]f"><field name="TEXT">Consider it done (;</field></shadow></value><value name="label"><shadow type="text" id="l.@_p[2f[j-Xv{YfpOs`"><field name="TEXT">You</field></shadow></value><next><block type="arcade_story_print_character_text" id="eg.YfZowh_C`x-zC.[-X"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="p#xv5M^oBt|9n(l#2oMq"><field name="TEXT">Finally ,a task worthy of my strength</field></shadow></value><value name="label"><shadow type="text" id="RszU/7v_S`:W/?`MZoq0"><field name="TEXT">Thor</field></shadow></value><next><block type="arcade_story_print_character_text" id=",akr0*D$ToksS,jdFN4o"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="TEt3SvYtDutU/w]hY08W"><field name="TEXT">Try not to break the universe, point break</field></shadow></value><value name="label"><shadow type="text" id="N`|Ll!apD7KE+^kh@D)%"><field name="TEXT">Ironman</field></shadow></value><next><block type="arcade_story_print_character_text" id="OdmT53f43KO[agyNfj6O"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="rOY3mL4z*~sdGFoLO)W/"><field name="TEXT">We regroup once we have them all . No detours</field></shadow></value><value name="label"><shadow type="text" id="x~5f{AP3ifqVFaGE|ajL"><field name="TEXT">cap</field></shadow></value><next><block type="arcade_story_print_character_text" id="|e8HlSbku}:B4s`HTkih"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="F~).PW_5X)7/jt)d{an:"><field name="TEXT">You have my word.</field></shadow></value><value name="label"><shadow type="text" id="tzxLb!EenkIYlqYyA4Bi"><field name="TEXT">Thor</field></shadow></value><next><block type="arcade_story_print_character_text" id="Edu6]F+EJm0uLDbgD#^f"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id=";3t{C(~BU(7Ti!d)2g5l"><field name="TEXT">Bet.</field></shadow></value><value name="label"><shadow type="text" id="w+C0_t*e7ECy4=)B./CT"><field name="TEXT">You</field></shadow></value><next><block type="arcade_story_print_character_text" id="aW+xpdIrhjw,C4cI3CK7"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="-]ELAg2o5rR:!txJfr~0"><field name="TEXT">That's exactly what I was afraid of.</field></shadow></value><value name="label"><shadow type="text" id="QH4V9suvKk8JRRd)qQ4|"><field name="TEXT">Ironman</field></shadow></value><next><block type="game_control_sprite" id="bT6j^n-yQ!#R]@?G)I:;"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="2" _input_init="true"></mutation><value name="sprite"><block type="variables_get" id="Y^*kNTKY)ahJo|FHzzMz"><field name="VAR" id="n8T;k+FN28dPRJVTdi+?">sprite</field></block></value><value name="vx"><shadow type="spriteSpeedPicker" id="!+91m/@c5eWX{:Rw:iI@"><field name="speed">100</field></shadow></value><value name="vy"><shadow type="spriteSpeedPicker" id="%_jqFIC$G@-VZN]^S(p0"><field name="speed">0</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement><next><block type="variables_set" id="YduPF1${qHk9s*/FT=z^"><field name="VAR" id="voba`Ld@._i.Gmpuz%YQ">dialog2</field><value name="VALUE"><shadow type="math_number" id="-Nkr%D`!Hp:0Bo,7mZR{"><field name="NUM">0</field></shadow><block type="logic_boolean" id="wFu.p8kqWY+hN#Jbbg~I"><field name="BOOL">TRUE</field></block></value></block></next></block></statement></block></statement></block><block type="spriteshittile" id="XI^E